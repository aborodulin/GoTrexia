<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Shell.NavBarIsVisible="False"
             SafeAreaEdges="None"
             x:Class="GoTrexia.AnswerPage">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <Grid Padding="24"
              RowDefinitions="Auto,Auto,Auto,*,*,*"
              RowSpacing="14">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <ImageButton x:Name="BackButtonImage"
                             BackgroundColor="Transparent"
                             WidthRequest="32"
                             HeightRequest="32"
                             IsEnabled="False" />

                <Border Grid.Column="1"
                        HorizontalOptions="End"
                        BackgroundColor="#66000000"
                        StrokeThickness="0"
                        Padding="10,6">
                    <Label x:Name="TotalScoreLabel"
                           FontSize="16"
                           TextColor="White" />
                </Border>
            </Grid>

            <Label x:Name="TitleLabel"
                   Grid.Row="1"
                   FontSize="30"
                   HorizontalOptions="Center"
                   TextColor="White" />

            <Label x:Name="AvailableScoreLabel"
                   Grid.Row="2"
                   FontSize="22"
                   HorizontalOptions="Center"
                   TextColor="White" />

            <VerticalStackLayout Grid.Row="3"
                                 Grid.RowSpan="3"
                                 Spacing="10"
                                 VerticalOptions="Center">
                <Button x:Name="AnswerButton1"
                        Clicked="OnAnswerClicked"
                        FontSize="18"
                        HeightRequest="72"
                        LineBreakMode="WordWrap" />

                <Button x:Name="AnswerButton2"
                        Clicked="OnAnswerClicked"
                        FontSize="18"
                        HeightRequest="72"
                        LineBreakMode="WordWrap" />

                <Button x:Name="AnswerButton3"
                        Clicked="OnAnswerClicked"
                        FontSize="18"
                        HeightRequest="72"
                        LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
