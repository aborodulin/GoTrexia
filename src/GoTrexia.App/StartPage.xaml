<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Shell.NavBarIsVisible="False"
             SafeAreaEdges="None"
             x:Class="GoTrexia.StartPage">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <Border BackgroundColor="#66000000"
                StrokeThickness="0"
                Padding="10,6"
                Margin="24,24,24,0"
                HorizontalOptions="End"
                VerticalOptions="Start">
            <Label x:Name="TotalScoreLabel"
                   FontSize="18"
                   TextColor="White" />
        </Border>

        <Grid Padding="24"
              RowDefinitions="Auto,*,Auto,Auto"
              RowSpacing="12">
            <Grid Grid.Row="0" HeightRequest="1" />

            <CollectionView x:Name="StagesCollectionView"
                            Grid.Row="1"
                            Margin="0,300,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="0"
                                BackgroundColor="#66000000"
                                Padding="10"
                                Margin="0,4">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <CheckBox IsChecked="{Binding IsChecked}"
                                          IsEnabled="False"
                                          VerticalOptions="Start" />

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           TextColor="White" />
                                    <Label Text="{Binding Score, StringFormat='Score: {0}'}"
                                           FontSize="12"
                                           TextColor="White" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button x:Name="StartButton"
                    Grid.Row="2"
                    Text="Start"
                    Clicked="OnStartClicked"
                    VerticalOptions="End" />

            <Button x:Name="AboutButton"
                    Grid.Row="3"
                    Text="About"
                    Clicked="OnAboutClicked"
                    VerticalOptions="End" />
        </Grid>
    </Grid>
</ContentPage>
