<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             Shell.NavBarIsVisible="False"
             SafeAreaEdges="None"
             x:Class="GoTrexia.MapPage">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <Label x:Name="StageTitleLabel"
                   Grid.Row="0"
                   FontSize="24"
                   HorizontalOptions="Center"
                   TextColor="White" />

            <Grid Grid.Row="1" HeightRequest="48">
                <Label x:Name="CountdownLabel"
                       FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="White" />

                <Button x:Name="HintButton"
                        Text="Hint"
                        IsVisible="False"
                        HeightRequest="48"
                        Clicked="OnHintClicked"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
            </Grid>

            <maps:Map x:Name="StageMap"
                      Grid.Row="2" />
        </Grid>
    </Grid>
</ContentPage>
