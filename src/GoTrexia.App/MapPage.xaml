<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             Shell.NavBarIsVisible="False"
             SafeAreaEdges="None"
             x:Class="GoTrexia.MapPage">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="10">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <ImageButton x:Name="BackButtonImage"
                             BackgroundColor="Transparent"
                             WidthRequest="32"
                             HeightRequest="32"
                             Clicked="OnBackClicked" />

                <Button x:Name="MapModeButton"
                        Grid.Column="1"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        HeightRequest="40"
                        Text="Map"
                        Clicked="OnMapModeButtonClicked" />

                <Border Grid.Column="2"
                        BackgroundColor="#66000000"
                        StrokeThickness="0"
                        Padding="10,6"
                        VerticalOptions="Start">
                    <Label x:Name="TotalScoreLabel"
                           FontSize="16"
                           TextColor="White" />
                </Border>
            </Grid>

            <Label x:Name="StageTitleLabel"
                   Grid.Row="1"
                   FontSize="29"
                   HorizontalOptions="Center"
                   TextColor="White">
                <Label.Shadow>
                    <Shadow Brush="Black" Offset="2,2" Radius="8" Opacity="1" />
                </Label.Shadow>
            </Label>

            <Label x:Name="HintLabel"
                   Grid.Row="2"
                   FontSize="19"
                   HorizontalOptions="Center"
                   IsVisible="True"
                   TextColor="White">
                <Label.Shadow>
                    <Shadow Brush="Black" Offset="2,2" Radius="8" Opacity="1" />
                </Label.Shadow>
            </Label>

            <Grid Grid.Row="3" HeightRequest="48">
                <Label x:Name="CountdownLabel"
                       FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="White" />

                <Button x:Name="HintButton"
                        Text="Hint"
                        IsVisible="False"
                        HeightRequest="48"
                        Clicked="OnHintClicked"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />

                <Button x:Name="CompleteButton"
                        Text="Complete"
                        IsVisible="False"
                        HeightRequest="48"
                        Clicked="OnCompleteClicked"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
            </Grid>

            <maps:Map x:Name="StageMap"
                      Grid.Row="4" />
        </Grid>
    </Grid>
</ContentPage>
