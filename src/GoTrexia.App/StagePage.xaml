<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="GoTrexia.StagePage">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill" />

        <Grid Padding="16"
              RowDefinitions="Auto,Auto,Auto,*,Auto"
              RowSpacing="10">
            <Label x:Name="StageTitleLabel"
                   Grid.Row="0"
                   FontSize="24"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label x:Name="StageDescriptionLabel"
                   Grid.Row="1"
                   FontSize="16"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label x:Name="StageScoreLabel"
                   Grid.Row="2"
                   FontSize="16"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <maps:Map x:Name="StageMap"
                      Grid.Row="3" />

            <Grid Grid.Row="4" ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="Complete"
                        Grid.Column="0"
                        IsEnabled="False"
                        Opacity="0.6" />

                <Button Text="Skip Stage"
                        Grid.Column="1"
                        Clicked="OnSkipClicked" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
