<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="GoTrexia.StagePage">
    <Grid>
        <Image x:Name="BackgroundImage"
               Aspect="AspectFill" />

        <VerticalStackLayout Padding="16" Spacing="10">
            <Label x:Name="StageTitleLabel"
                   FontSize="24"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label x:Name="StageDescriptionLabel"
                   FontSize="16"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label x:Name="StageScoreLabel"
                   FontSize="16"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <maps:Map x:Name="StageMap"
                      HeightRequest="320" />

            <Button Text="Skip Stage"
                    Clicked="OnSkipClicked" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
